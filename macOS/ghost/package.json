{
  "name": "@ghostui/ghost",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "gui": "./src/cli/main.ts"
  },
  "scripts": {
    "bench:ax-events": "bun run src/a11y/ax-event-throughput.ts",
    "build:display-ui": "bun run src/build/display-ui.ts",
    "dev": "bun run build:display-ui && bun run src/daemon.ts",
    "bench:vat-observer": "bun run src/a11y/vat-observer.bench.ts",
    "lint:ts": "eslint src",
    "typecheck:display-ui": "tsc --noEmit -p tsconfig.display-ui.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "htm": "^3.1.1",
    "preact": "^10.27.2",
    "@vscode/codicons": "^0.0.45",
    "seti-ui": "^1.11.0",
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "playwright": "^1.58.2",
    "typescript": "^5.9.0"
  }
}
